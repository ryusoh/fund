{
    "name": "fund-frontend",
    "version": "1.0.0",
    "description": "Frontend for the fund project",
    "main": "js/main.js",
    "scripts": {
        "test": "TZ=UTC NODE_NO_WARNINGS=1 jest --coverage",
        "dev": "python3 scripts/dev_server.py 8000",
        "lint:js": "eslint .",
        "lint:css": "stylelint \"**/*.css\"",
        "lint": "npm run lint:js && npm run lint:css",
        "typecheck:js": "tsc -p jsconfig.json",
        "lint:fix": "eslint . --fix && stylelint \"**/*.css\" --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "verify:all": "npm run lint && npm test && ruff check scripts tests/python && black --check . && mypy && bandit -r scripts -lll && pytest",
        "verify:fix": "ruff check --fix scripts tests/python && black . && npm run verify:all",
        "prepare": "husky install",
        "vendor:fetch": "node scripts/vendor/fetch_vendor.js",
        "vendor:verify": "node scripts/vendor/check_vendor.js",
        "vendor:clean": "node scripts/vendor/clean_vendor.js",
        "vendor:refresh": "npm run vendor:clean && npm run vendor:fetch",
        "vendor:build-calendar": "node scripts/build-calendar.js",
        "fund": "python3 -m scripts.cli",
        "fund:holdings": "python3 -m scripts.cli holdings",
        "fund:forex": "python3 -m scripts.cli forex",
        "fund:data": "python3 -m scripts.cli fund-data",
        "fund:pnl": "python3 -m scripts.cli daily-pnl",
        "fund:history": "python3 -m scripts.cli extract-history",
        "fund:update-all": "python3 -m scripts.cli update-all"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@popperjs/core": "^2.11.8",
        "@stylistic/stylelint-plugin": "^5.2.1",
        "@testing-library/jest-dom": "^6.9.1",
        "babel-jest": "^30.4.1",
        "d3-color": "^3.1.0",
        "d3-fetch": "^3.0.1",
        "d3-selection": "^3.0.0",
        "dayjs": "^1.11.21",
        "esbuild": "^0.28.1",
        "eslint": "^10.7.0",
        "eventemitter3": "^5.0.4",
        "husky": "^9.1.6",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "js-yaml": "^4.1.1",
        "lint-staged": "^17.0.8",
        "lodash-es": "^4.18.1",
        "markdownlint-cli2": "^0.23.0",
        "playwright": "^1.61.1",
        "prettier": "^3.9.5",
        "stylelint": "^17.14.0",
        "stylelint-config-standard": "^40.0.0",
        "typescript": "^7.0.2",
        "wrangler": "^4.110.0"
    },
    "lint-staged": {
        "*.js": [
            "prettier --write --ignore-path .prettierignore",
            "eslint --fix"
        ],
        "*.css": [
            "prettier --write --ignore-path .prettierignore",
            "stylelint --fix"
        ],
        "*.{md,json,html,yml,yaml}": [
            "prettier --write --ignore-path .prettierignore"
        ]
    },
    "jest": {
        "silent": true,
        "testEnvironment": "jsdom",
        "testEnvironmentOptions": {
            "url": "http://localhost",
            "console": "off"
        },
        "testMatch": [
            "<rootDir>/tests/js/**/*.test.js"
        ],
        "modulePathIgnorePatterns": [
            "<rootDir>/venv/",
            "<rootDir>/.claude/"
        ],
        "collectCoverageFrom": [
            "js/**/*.js",
            "!js/vendor/**"
        ],
        "coverageThreshold": {},
        "transform": {
            "^.+\\.js$": "babel-jest"
        },
        "moduleNameMapper": {
            "^d3$": "<rootDir>/js/vendor/d3.v7.mjs",
            "^@js/(.*)$": "<rootDir>/js/$1",
            "^@pages/(.*)$": "<rootDir>/js/pages/$1",
            "^@services/(.*)$": "<rootDir>/js/services/$1",
            "^@charts/(.*)$": "<rootDir>/js/charts/$1",
            "^@plugins/(.*)$": "<rootDir>/js/plugins/$1",
            "^@ui/(.*)$": "<rootDir>/js/ui/$1",
            "^@utils/(.*)$": "<rootDir>/js/utils/$1",
            "^@vendor/(.*)$": "<rootDir>/tests/js/__mocks__/vendor/$1",
            "^\\.\\.\\/\\.\\.\\/vendor/perlin-plane\\.js$": "<rootDir>/tests/js/__mocks__/vendor/perlin-plane.js"
        }
    },
    "overrides": {
        "js-yaml": "^4.1.1",
        "minimatch": "^3.1.2"
    }
}
