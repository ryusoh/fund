# Python virtual environment (no trailing slash: also matches a venv symlink)
venv
.venv
**/__pycache__/
__pycache__/
*.pyc
assets/.DS_Store
assets/logo/.DS_Store
node_modules/
# Test coverage reports
coverage/
# Headless screenshot output (visual verification, scripts/screenshot.mjs)
screenshots/
.DS_Store

# Gemini CLI: share reusable commands, keep memory/state (GEMINI.md) local.
.gemini/*
!.gemini/commands/

# VS Code workspace files
*.code-workspace
.coverage

# Wrangler build cache
worker/.wrangler/

# Coverage artifacts
.coverage*

# Claude Code: share reusable agent assets, keep personal/transient state local.
.claude/*
!.claude/commands/
!.claude/agents/
!.claude/skills/
!.claude/settings.json
!.claude/launch.json
# (still ignored by .claude/*: settings.local.json — personal; worktrees/ — transient)

# Transient agent artifacts / PR details
pr_body.txt
pr_title.txt
commit_message.txt
